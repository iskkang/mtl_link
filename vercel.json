{
  "regions": ["icn1"],
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=()"
        },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/fesco/container-cleanup",     "destination": "/api/fesco/container-cleanup.ts" },
    { "source": "/api/fesco/weekly-report",         "destination": "/api/fesco/weekly-report.ts" },
    { "source": "/api/fesco/container-tracking-cron", "destination": "/api/fesco/container-tracking-cron.ts" },
    { "source": "/((?!api/|@|src/|node_modules/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/fesco/weekly-report",           "schedule": "0 0 * * 1" },
    { "path": "/api/tcr?action=delay-notify",       "schedule": "0 1 * * *" },
    { "path": "/api/fesco/container-tracking-cron", "schedule": "0 */4 * * *" }
  ]
}
