# Supabase (supabase.com 대시보드 → Project Settings → API 에서 복사)
VITE_SUPABASE_URL=https://<프로젝트-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# 앱 설정
VITE_APP_NAME=MTL Link
VITE_ENV=development

# logisight 연동 (선택) — /api/tcr?action=corridor-stats 엔드포인트 보호
# 비워두면 인증 없이 열려있음. 설정하면 Bearer 토큰 검증.
LOGISIGHT_API_KEY=
